# Database
DATABASE_URL="postgresql://postgres:yourpassword@localhost:5432/globall_cloud"

# Server
PORT=5000
NODE_ENV=development

# JWT
JWT_SECRET="your-super-secret-key-change-this-in-production"
JWT_EXPIRES_IN="7d"

# Payment - FIB
FIB_API_URL="https://fib-api-url.com"
FIB_MERCHANT_ID="your-merchant-id"
FIB_API_KEY="your-api-key"

# Payment - Qi Card
QI_CARD_API_URL="https://qicard-api-url.com"
QI_CARD_MERCHANT_ID="your-merchant-id"
QI_CARD_API_KEY="your-api-key"

# File Upload
UPLOAD_DIR="./uploads"
MAX_FILE_SIZE=10485760

# CORS
FRONTEND_URL="http://localhost:3000"
ADMIN_URL="http://localhost:3001"
